# DeepSeek 对话模型
OPENAI_API_KEY=xxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
MAX_TOKENS=4000

# 硅基流动 Embedding
EMBEDDING_API_KEY=xxxxxxxxx
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# 数据库配置
SQLITE_DB_PATH=./customer_support_chat/data/travel2.sqlite
LOG_LEVEL=DEBUG

# AviationStack 实时航班 API (免费注册: https://aviationstack.com)
AVIATIONSTACK_API_KEY=xxxxxx

# 聚合数据 国内航班查询 API (注册: https://www.juhe.cn/docs/api/id/818)
JUHE_FLIGHT_KEY=xxxxxx

# Tavily 搜索 API (推荐，免费额度: https://tavily.com)
TAVILY_API_KEY=xxxxxx

# 滴滴 MCP (注册: https://mcp.didichuxing.com)
DID_MCP_KEY=xxxxxx

# 携程/酒店 API via OneBound (注册: https://open.onebound.cn)
# 注意: OneBound携程接口仅支持酒店/景点，不支持航班查询
CTRIP_APP_KEY=xxxxxx
CTRIP_APP_SECRET=xxxxxx